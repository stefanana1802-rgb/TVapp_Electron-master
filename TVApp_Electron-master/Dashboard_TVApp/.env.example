# Calea către directorul WORKSPACE al TV App (relativă la Dashboard_TVApp sau absolută)
WORKSPACE_PATH=../WORKSPACE

# Dashboard ascultă pe toate interfețele (0.0.0.0) = acces din rețea. Doar local: 127.0.0.1
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# Server: implicit Waitress (WSGI). Pentru serverul de dezvoltare Flask: decomentează linia de mai jos
# USE_WAITRESS=0

# La pornire, dashboard-ul se înregistrează în WORKSPACE/dashboard_sources.json și face push în Git (pentru Launcher).
# Pentru a nu înregistra acest PC în listă: decomentează linia de mai jos
# REGISTER_DASHBOARD=0
