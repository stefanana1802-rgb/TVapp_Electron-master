# Copiază în .env și completează valorile. Fișierul .env nu se comite în Git.

# ========== Opțional ==========
# USE_DEV_SERVER=1          # server Vite la develop
# DISABLE_GPU=1              # pe RDP/VM dacă apar erori GPU
# UPDATE_FEED_URL=...        # URL feed update
# GOOGLE_MAPS_API_KEY=...    # traffic
# GOOGLE_PLACES_API_KEY=...  # restaurant of the day
#
# Cantină – descărcare automată PDF (login pe locația din dashboard)
# CANTEEN_LOGIN_EMAIL=cont@company.com
# CANTEEN_LOGIN_PASSWORD=parola_ta
# CANTEEN_MENU_TEST_SHOW=1   # pentru test: afișează meniul cantină la deschidere (~8 s). Dezactivează pentru producție – rulare doar la time slot din dashboard
# (Login + descărcare SharePoint rulează mereu în background, fără fereastră vizibilă.)
# CANTEEN_ALWAYS_SHOW=1      # 1 = afișează tot timpul secțiunea Canteen (nu Traffic); 0 sau lipsă = regula normală (15–18 Traffic)
# TRAFFIC_ALWAYS_SHOW=1     # 1 = afișează tot timpul Traffic; 0 sau lipsă = regula normală. Dacă ambele 1, câștigă Canteen

# ========== Microsoft – conținut protejat în slideshow (Power BI) ==========
# Login la pornire (o singură dată). URL-urile reportelor pui doar în playlist (slide type: powerbi).
# MSAL_DIRECT_LOGIN_URL=https://app.powerbi.com   # sau URL complet al oricărui report (doar pentru login)
# Auto-completare formular la pornire:
# MSAL_LOGIN_EMAIL=cont@company.com
# MSAL_LOGIN_PASSWORD=parola_ta
# MSAL_LOGIN_HINT=email@company.com   # doar cu AZURE_CLIENT_ID; precompletează emailul
#
# Variantă 2 – OAuth (Azure): App registration → Redirect URI tvapp://auth
# AZURE_CLIENT_ID=...
# AZURE_TENANT_ID=...   # sau "common"
# MSAL_SCOPES=openid profile user.read
#
# Flightboard SimpleView (iframe wpp în player): zoom 0.1–2, implicit 0.6 dacă lipsește
# VITE_FLIGHTBOARD_SIMPLEVIEW_IFRAME_SCALE=0.6
